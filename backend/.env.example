# ─────────────────────────────────────────────────────────────
# TrampoHero Backend – Environment Variables
# Copy this file to backend/.env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/trampohero

# JWT signing secret – change this to a long random string in production (required)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Google Gemini API key (required for AI features – stays server-side only)
GEMINI_API_KEY=your_gemini_api_key_here

# Payment gateway (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# CORS – comma-separated list of allowed origins.
# In production set this to your deployed frontend URL(s).
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Global API rate-limit (requests per 15 min per IP, default 100)
RATE_LIMIT_MAX=100

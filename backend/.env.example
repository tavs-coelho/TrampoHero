# ─────────────────────────────────────────────────────────────
# TrampoHero Backend – Environment Variables
# Copy this file to backend/.env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/trampohero

# JWT signing secret – change this to a long random string in production (required)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Google Gemini API key (optional – used for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Payment gateway (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# CORS – comma-separated list of allowed origins.
# In production set this to your deployed frontend URL(s).
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Azure Blob Storage (SAS upload support) ─────────────────────────────────
# Obtain from Azure Portal → Storage Accounts → your account → Access keys
# In production, store the key in Azure Key Vault and reference it via a
# Key Vault reference secret, never hardcode it here.
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key_base64
AZURE_STORAGE_CONTAINER_NAME=uploads

# ── Azure Web PubSub (real-time chat) ───────────────────────────────────────
# Obtain from Azure Portal → Web PubSub → Keys → Primary connection string
WEB_PUBSUB_CONNECTION_STRING=Endpoint=https://your-hub.webpubsub.azure.com;AccessKey=...;Version=1.0;
WEB_PUBSUB_HUB_NAME=chat

# ── Azure Notification Hubs (push notifications) ────────────────────────────
# Obtain from Azure Portal → Notification Hubs → your hub → Access Policies
# Use the DefaultFullSharedAccessSignature connection string (server side only).
NH_CONNECTION_STRING=Endpoint=sb://your-ns.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;SharedAccessKey=...
NH_HUB_NAME=trampohero

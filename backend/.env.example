PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/trampohero
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRE=30d

# Gemini AI — stays server-side only; never sent to the client
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe (optional – payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# CORS — primary frontend URL
FRONTEND_URL=http://localhost:3000

# CORS — additional comma-separated origins (staging, preview URLs, etc.)
# Example: ALLOWED_ORIGINS=https://staging.trampohero.com,https://preview-abc.vercel.app
ALLOWED_ORIGINS=

# Global API rate-limit (requests per 15 min per IP, default 100)
RATE_LIMIT_MAX=100

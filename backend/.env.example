# ─────────────────────────────────────────────────────────────
# TrampoHero Backend – Environment Variables
# Copy this file to backend/.env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/trampohero

# JWT signing secret – change this to a long random string in production (required)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
# Access token lifetime (default: 1h). Short values improve security.
JWT_EXPIRE=1h
# Separate secret for refresh tokens – defaults to JWT_SECRET+"_refresh" if omitted.
# Set an independent secret in production.
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_REFRESH_EXPIRE=30d

# Google Gemini API key (required for AI features – stays server-side only)
# Google Gemini API key (optional – used for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Payment gateway (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Azure Blob Storage – required for photo upload (SAS) endpoints.
# Leave blank to disable upload endpoints gracefully.
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER_NAME=uploads

# CORS – comma-separated list of allowed origins.
# In production set this to your deployed frontend URL(s).
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Global API rate-limit (requests per 15 min per IP, default 100)
RATE_LIMIT_MAX=100

# Auth-specific rate-limit – applies to login, register, forgot-password
# (max attempts per window before IP is blocked; default: 10 per 15 min)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Email (SMTP) – set EMAIL_ENABLED=true and fill in SMTP_* to enable transactional emails.
# When EMAIL_ENABLED=false (default) emails are logged to console (dev-friendly).
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@trampohero.com.br

# Azure Notification Hubs – required for push notification endpoints.
# Leave blank to disable push endpoints gracefully.
# Connection string from Azure portal → Notification Hub → Access Policies → DefaultFullSharedAccessSignature
ANH_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;SharedAccessKey=<key>
ANH_HUB_NAME=your_notification_hub_name

# Azure Web PubSub – required for real-time chat token endpoint.
# Leave blank to fall back to a mock JWT token.
AZURE_WEBPUBSUB_CONNECTION_STRING=Endpoint=https://<resource>.webpubsub.azure.com;AccessKey=<key>;Version=1.0;
AZURE_WEBPUBSUB_HUB_NAME=your_hub_name

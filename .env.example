# ─────────────────────────────────────────────────────────────
# TrampoHero Frontend – Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Stripe publishable key (pk_test_... for test environment, pk_live_... for production)
# Obtain at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# (Optional) Application display name
# VITE_APP_NAME=TrampoHero

# NOTE: GEMINI_API_KEY belongs in the backend (backend/.env) only.
# AI calls are proxied through the backend at POST /api/ai/generate.
# The key is NEVER set here — see backend/.env.example.
# See DEPLOYMENT.md for full setup instructions.

# ─────────────────────────────────────────────────────────────
# Mobile app variables – see apps/mobile/.env.example for full list.
# Copy apps/mobile/.env.example to apps/mobile/.env for mobile dev.
# ─────────────────────────────────────────────────────────────
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api

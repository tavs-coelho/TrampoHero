# ─── Frontend (Vite) environment variables ────────────────────────────────────
# Only VITE_* variables are exposed to the browser bundle.
# Never put secrets (API keys, passwords) in VITE_* vars.

# URL of the backend API (include /api suffix)
VITE_API_URL=http://localhost:5000/api

# ─── NOT needed in the frontend any more ──────────────────────────────────────
# GEMINI_API_KEY has been moved to the backend (backend/.env).
# See DEPLOYMENT.md for the full setup guide.

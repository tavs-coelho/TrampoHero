# ─────────────────────────────────────────────────────────────
# TrampoHero Mobile – Environment Variables
# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are exposed to the app bundle.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Backend API base URL (replace with staging/production URL as needed)
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Azure Notification Hubs (for push notifications)
# Obtain from Azure Portal > Notification Hubs > Access Policies
EXPO_PUBLIC_ANH_CONNECTION_STRING=Endpoint=sb://YOUR_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=DefaultListenSharedAccessSignature;SharedAccessKey=YOUR_KEY
EXPO_PUBLIC_ANH_HUB_NAME=trampohero-notifications

# Azure Web PubSub (for real-time chat)
# Obtain from Azure Portal > Web PubSub > Keys
EXPO_PUBLIC_WEB_PUBSUB_URL=wss://YOUR_WEBPUBSUB.webpubsub.azure.com/client/hubs/chat

# Feature flags
EXPO_PUBLIC_ENABLE_CHAT=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_MAP=true

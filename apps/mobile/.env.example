# ─────────────────────────────────────────────────────────────
# TrampoHero Mobile – Environment Variables
# Copy this file to apps/mobile/.env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the app.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Backend API base URL (required)
# Development: point to local backend
# Production: point to your Azure App Service URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api
